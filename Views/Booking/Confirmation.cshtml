@model SeanRaw.Web.Models.Booking
@{
    ViewData["Title"] = "Xác nhận đặt lịch";
}

<!-- ── CONTENT ───────────────────────────────────────────── -->
<section style="padding: 100px 64px; min-height: 70vh; display: flex; align-items: center;">
    <div style="max-width: 700px; margin: 0 auto; width: 100%;">

        <!-- Success Icon -->
        <div style="text-align: center; margin-bottom: 48px;">
            <p style="font-size: 64px; margin: 0 0 24px 0;">✅</p>
            <p class="section-eyebrow" style="text-align: center;">Đặt lịch thành công</p>
            <h1 class="hero-title" style="margin-bottom: 16px;">Cảm ơn bạn!</h1>
            <p class="hero-sub" style="color: var(--silver);">
                Lịch chụp của bạn đã được ghi nhận. Vui lòng đặt cọc để xác nhận và giữ lịch.
            </p>
        </div>

        <!-- Booking Summary Card -->
        <div style="border: 1px solid var(--border); border-radius: 2px; background: var(--surface); padding: 40px; margin-bottom: 40px;">
            <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 24px; border-bottom: 1px solid var(--border); margin-bottom: 24px;">
                <h2 style="font-family: var(--ff-display); font-size: 22px; color: var(--white); margin: 0; font-weight: 400;">
                    Booking #@Model.IdBooking
                </h2>
                <span style="background: rgba(201, 168, 76, 0.1); color: var(--gold); padding: 6px 12px; border-radius: 2px; font-size: 12px;">Chờ đặt cọc</span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                <div>
                    <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 8px 0;">Nhiếp ảnh gia</p>
                    <p style="color: var(--white); font-size: 16px; margin: 0;">@Model.Photographer?.HoTenDayDu</p>
                </div>
                <div>
                    <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 8px 0;">Gói dịch vụ</p>
                    <p style="color: var(--white); font-size: 16px; margin: 0;">@Model.ServicePackage?.TenGoi</p>
                </div>
                <div>
                    <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 8px 0;">Ngày chụp</p>
                    <p style="color: var(--white); font-size: 16px; margin: 0;">@Model.NgayChupThucTe.ToString("dd/MM/yyyy")</p>
                </div>
                <div>
                    <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 8px 0;">Khung giờ</p>
                    <p style="color: var(--white); font-size: 16px; margin: 0;">@Model.KhungGioChup</p>
                </div>
                <div style="grid-column: 1 / -1;">
                    <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 8px 0;">Địa điểm chụp</p>
                    <p style="color: var(--white); font-size: 16px; margin: 0;">📍 @Model.DiaDiemChup</p>
                </div>
            </div>

            <div style="margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                <p style="color: var(--silver); font-size: 14px; margin: 0;">Tổng giá trị hợp đồng</p>
                <p style="color: var(--gold); font-size: 24px; margin: 0; font-family: var(--ff-display);">@Model.TongTienHopDong.ToString("N0") ₫</p>
            </div>
        </div>

        <!-- Actions -->
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="/Booking/Detail/@Model.IdBooking" class="btn-gold" style="border: none; cursor: pointer; font-family: var(--ff-body); text-decoration: none;">
                Xem chi tiết & thanh toán cọc
            </a>
            <a href="/Customer/Bookings" class="btn-ghost">
                Xem lịch sử đặt lịch
            </a>
        </div>

        <!-- Footer -->
        <div style="margin-top: 60px; text-align: center; padding-top: 40px; border-top: 1px solid var(--border);">
            <a href="/" class="btn-ghost">
                ← Quay lại trang chủ
            </a>
        </div>

    </div>
</section>
