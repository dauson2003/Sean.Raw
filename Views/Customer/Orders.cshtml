@model List<SeanRaw.Web.Models.StoreOrder>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<!-- ── HEADER ────────────────────────────────────────────── -->
<section style="padding: 60px 64px; background: linear-gradient(135deg, var(--ink-soft) 0%, var(--ink-mid) 100%); border-bottom: 1px solid var(--border);">
    <div style="max-width: 1200px; margin: 0 auto;">
        <p class="section-eyebrow">Mua sắm</p>
        <h1 class="hero-title" style="margin-bottom: 0;">Lịch sử đơn hàng</h1>
        <p class="hero-sub" style="color: var(--silver);">Xem chi tiết các đơn hàng đã mua</p>
    </div>
</section>

<!-- ── CONTENT ───────────────────────────────────────────── -->
<section style="padding: 60px 64px;">
    <div style="max-width: 1200px; margin: 0 auto;">

        @if (Model != null && Model.Any())
        {
            <!-- Filters -->
            <div style="display: flex; gap: 16px; margin-bottom: 40px; flex-wrap: wrap;">
                <select style="border: 1px solid var(--border); background: var(--surface); color: var(--white); padding: 12px 16px; border-radius: 2px; font-family: var(--ff-body);">
                    <option>Tất cả trạng thái</option>
                    <option>Đang giao</option>
                    <option>Đã giao</option>
                    <option>Hủy</option>
                </select>
                <input type="date" style="border: 1px solid var(--border); background: var(--surface); color: var(--white); padding: 12px 16px; border-radius: 2px; font-family: var(--ff-body);" />
            </div>

            <!-- Orders Table -->
            <div style="border: 1px solid var(--border); border-radius: 2px; overflow: hidden;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--surface); border-bottom: 2px solid var(--gold);">
                            <th style="padding: 16px; text-align: left; color: var(--gold); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;">Mã đơn</th>
                            <th style="padding: 16px; text-align: left; color: var(--gold); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;">Ngày đặt</th>
                            <th style="padding: 16px; text-align: left; color: var(--gold); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;">Số lượng</th>
                            <th style="padding: 16px; text-align: left; color: var(--gold); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;">Tổng tiền</th>
                            <th style="padding: 16px; text-align: left; color: var(--gold); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;">Trạng thái</th>
                            <th style="padding: 16px; text-align: center; color: var(--gold); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: 16px; color: var(--white); font-weight: 500;">#@order.IdDonHang</td>
                                <td style="padding: 16px; color: var(--silver);">@order.NgayDatHang.ToString("dd/MM/yyyy")</td>
                                <td style="padding: 16px; color: var(--silver);">@order.OrderItems?.Count ?? 0 sản phẩm</td>
                                <td style="padding: 16px; color: var(--white); font-weight: 500;">@order.TongTienHoaDon.ToString("N0") ₫</td>
                                <td style="padding: 16px;">
                                    @if (order.TrangThaiThanhToan == "cho_thanh_toan")
                                    {
                                        <span style="background: rgba(201, 168, 76, 0.1); color: var(--gold); padding: 6px 12px; border-radius: 2px; font-size: 12px;">Chờ thanh toán</span>
                                    }
                                    else if (order.TrangThaiThanhToan == "da_thanh_toan")
                                    {
                                        <span style="background: rgba(74, 158, 100, 0.1); color: #4a9e64; padding: 6px 12px; border-radius: 2px; font-size: 12px;">Đã thanh toán</span>
                                    }
                                    else if (order.TrangThaiThanhToan == "huy")
                                    {
                                        <span style="background: rgba(217, 68, 68, 0.1); color: #d94444; padding: 6px 12px; border-radius: 2px; font-size: 12px;">Hủy</span>
                                    }
                                </td>
                                <td style="padding: 16px; text-align: center;">
                                    <a href="/Customer/Orders/@order.IdDonHang" style="color: var(--gold); text-decoration: underline; font-size: 12px; cursor: pointer;">
                                        Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div style="display: flex; justify-content: center; gap: 12px; margin-top: 40px; align-items: center;">
                <a href="#" style="color: var(--gold); text-decoration: underline; font-size: 12px;">← Trước</a>
                <span style="color: var(--gold); padding: 6px 12px; background: var(--surface); border: 1px solid var(--gold); border-radius: 2px;">1</span>
                <span style="color: var(--silver); padding: 6px 12px; border: 1px solid var(--border); border-radius: 2px; cursor: pointer;">2</span>
                <span style="color: var(--silver); padding: 6px 12px; border: 1px solid var(--border); border-radius: 2px; cursor: pointer;">3</span>
                <a href="#" style="color: var(--gold); text-decoration: underline; font-size: 12px;">Sau →</a>
            </div>

            <!-- Summary -->
            <div style="margin-top: 60px; padding-top: 40px; border-top: 1px solid var(--border); text-align: center;">
                <p style="color: var(--silver); font-size: 14px; margin: 0;">
                    Tổng cộng: <strong style="color: var(--white);">@Model.Count</strong> đơn hàng
                </p>
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div style="text-align: center; padding: 100px 24px;">
                <p style="font-size: 64px; margin: 0 0 20px 0;">🛍️</p>
                <h2 style="font-family: var(--ff-display); font-size: 28px; color: var(--white); margin: 0 0 12px 0; font-weight: 400;">
                    Chưa có đơn hàng nào
                </h2>
                <p style="color: var(--silver); font-size: 16px; margin: 0 0 40px 0;">
                    Bắt đầu mua sắm phụ kiện chuyên nghiệp ngay hôm nay.
                </p>
                <a href="/Home/Store" class="btn-ghost">
                    Xem cửa hàng →
                </a>
            </div>
        }

        <!-- Footer -->
        <div style="margin-top: 60px; text-align: center; padding-top: 40px; border-top: 1px solid var(--border);">
            <a href="/Customer/Dashboard" class="btn-ghost">
                ← Quay lại Dashboard
            </a>
        </div>

    </div>
</section>
