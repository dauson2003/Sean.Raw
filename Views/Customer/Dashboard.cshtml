@model List<SeanRaw.Web.Models.Booking>
@{
    ViewData["Title"] = "Dashboard - Khách hàng";
}

<!-- ── HEADER ────────────────────────────────────────────── -->
<section style="padding: 60px 64px; background: linear-gradient(135deg, var(--ink-soft) 0%, var(--ink-mid) 100%); border-bottom: 1px solid var(--border);">
    <div style="max-width: 1200px; margin: 0 auto;">
        <p class="section-eyebrow">Bảng điều khiển</p>
        <h1 class="hero-title" style="margin-bottom: 0;">Dashboard Khách hàng</h1>
    </div>
</section>

<!-- ── STATS CARDS ────────────────────────────────────────── -->
<section style="padding: 60px 64px;">
    <div style="max-width: 1200px; margin: 0 auto;">
        
        <!-- Quick Stats -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px; margin-bottom: 60px;">
            
            <!-- Total Bookings -->
            <div style="border: 1px solid var(--border); padding: 32px; border-radius: 2px; background: var(--surface);">
                <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 12px 0;">
                    📅 Tổng số buổi chụp
                </p>
                <p style="font-family: var(--ff-display); font-size: 36px; color: var(--white); margin: 0 0 8px 0; font-weight: 300;">
                    @ViewBag.TotalBookings
                </p>
                <p style="color: var(--silver); font-size: 13px; margin: 0;">
                    Buổi chụp đã đặt
                </p>
            </div>

            <!-- Pending Bookings -->
            <div style="border: 1px solid var(--border); padding: 32px; border-radius: 2px; background: var(--surface);">
                <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 12px 0;">
                    ⏳ Chờ xác nhận
                </p>
                <p style="font-family: var(--ff-display); font-size: 36px; color: var(--white); margin: 0 0 8px 0; font-weight: 300;">
                    @ViewBag.PendingBookings
                </p>
                <p style="color: var(--silver); font-size: 13px; margin: 0;">
                    Buổi chụp đang chờ
                </p>
            </div>

            <!-- Completed Bookings -->
            <div style="border: 1px solid var(--border); padding: 32px; border-radius: 2px; background: var(--surface);">
                <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 12px 0;">
                    ✅ Hoàn tất
                </p>
                <p style="font-family: var(--ff-display); font-size: 36px; color: var(--white); margin: 0 0 8px 0; font-weight: 300;">
                    @ViewBag.CompletedBookings
                </p>
                <p style="color: var(--silver); font-size: 13px; margin: 0;">
                    Buổi chụp đã hoàn tất
                </p>
            </div>

            <!-- Total Spent -->
            <div style="border: 1px solid var(--border); padding: 32px; border-radius: 2px; background: var(--surface);">
                <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 12px 0;">
                    💳 Tổng chi tiêu
                </p>
                <p style="font-family: var(--ff-display); font-size: 36px; color: var(--white); margin: 0 0 8px 0; font-weight: 300;">
                    @(ViewBag.TotalSpent > 0 ? ((long)ViewBag.TotalSpent).ToString("N0") : "0") ₫
                </p>
                <p style="color: var(--silver); font-size: 13px; margin: 0;">
                    Tổng tiền đã thanh toán
                </p>
            </div>

        </div>

        <!-- Menu Actions -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 60px;">
            <a href="/Booking/Create" style="border: 1px solid var(--border); padding: 24px; text-align: center; display: block; text-decoration: none; color: var(--white); transition: all 0.3s; border-radius: 2px;">
                <p style="font-size: 24px; margin: 0 0 8px 0;">📷</p>
                <p style="font-size: 14px; font-weight: 500; margin: 0;">Đặt lịch</p>
                <p style="font-size: 12px; color: var(--silver); margin: 4px 0 0 0;">Đặt buổi chụp mới</p>
            </a>
            <a href="/Customer/Bookings" style="border: 1px solid var(--border); padding: 24px; text-align: center; display: block; text-decoration: none; color: var(--white); transition: all 0.3s; border-radius: 2px;">
                <p style="font-size: 24px; margin: 0 0 8px 0;">📅</p>
                <p style="font-size: 14px; font-weight: 500; margin: 0;">Lịch sử</p>
                <p style="font-size: 12px; color: var(--silver); margin: 4px 0 0 0;">Xem lịch sử đặt lịch</p>
            </a>
            <a href="/Customer/Albums" style="border: 1px solid var(--border); padding: 24px; text-align: center; display: block; text-decoration: none; color: var(--white); transition: all 0.3s; border-radius: 2px;">
                <p style="font-size: 24px; margin: 0 0 8px 0;">🖼️</p>
                <p style="font-size: 14px; font-weight: 500; margin: 0;">Ảnh của tôi</p>
                <p style="font-size: 12px; color: var(--silver); margin: 4px 0 0 0;">Thư viện ảnh</p>
            </a>
            <a href="/Customer/Orders" style="border: 1px solid var(--border); padding: 24px; text-align: center; display: block; text-decoration: none; color: var(--white); transition: all 0.3s; border-radius: 2px;">
                <p style="font-size: 24px; margin: 0 0 8px 0;">🛍️</p>
                <p style="font-size: 14px; font-weight: 500; margin: 0;">Đơn hàng</p>
                <p style="font-size: 12px; color: var(--silver); margin: 4px 0 0 0;">Lịch sử mua sắm</p>
            </a>
            <a href="/Customer/Reviews" style="border: 1px solid var(--border); padding: 24px; text-align: center; display: block; text-decoration: none; color: var(--white); transition: all 0.3s; border-radius: 2px;">
                <p style="font-size: 24px; margin: 0 0 8px 0;">⭐</p>
                <p style="font-size: 14px; font-weight: 500; margin: 0;">Đánh giá</p>
                <p style="font-size: 12px; color: var(--silver); margin: 4px 0 0 0;">Đánh giá thợ ảnh</p>
            </a>
            <a href="/Customer/Profile" style="border: 1px solid var(--border); padding: 24px; text-align: center; display: block; text-decoration: none; color: var(--white); transition: all 0.3s; border-radius: 2px;">
                <p style="font-size: 24px; margin: 0 0 8px 0;">👤</p>
                <p style="font-size: 14px; font-weight: 500; margin: 0;">Hồ sơ</p>
                <p style="font-size: 12px; color: var(--silver); margin: 4px 0 0 0;">Cập nhật thông tin</p>
            </a>
        </div>

        <!-- Recent Bookings -->
        <div style="border-top: 1px solid var(--border); padding-top: 60px;">
            <h2 class="section-title" style="margin-bottom: 40px;">Buổi chụp gần đây</h2>

            @if (Model != null && Model.Any())
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
                    @foreach (var booking in Model.Take(6))
                    {
                        <div style="border: 1px solid var(--border); padding: 24px; border-radius: 2px; display: flex; flex-direction: column;">
                            <!-- Header -->
                            <div style="margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border);">
                                <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; margin: 0;">Buổi #@booking.IdBooking</p>
                                <p style="color: var(--white); font-size: 16px; font-weight: 500; margin: 8px 0 0 0;">@booking.ServicePackage?.TenGoi</p>
                            </div>

                            <!-- Details -->
                            <div style="margin-bottom: 16px; flex: 1;">
                                <p style="color: var(--silver); font-size: 13px; margin: 0 0 8px 0;">
                                    <span style="color: var(--gold);">📅</span> @booking.NgayChupThucTe.ToString("dd/MM/yyyy")
                                </p>
                                <p style="color: var(--silver); font-size: 13px; margin: 0 0 8px 0;">
                                    <span style="color: var(--gold);">👤</span> @booking.Photographer?.HoTenDayDu
                                </p>
                                <p style="color: var(--white); font-size: 14px; font-weight: 500; margin: 0;">
                                    @booking.TongTienHopDong.ToString("N0") ₫
                                </p>
                            </div>

                            <!-- Status -->
                            <div style="margin-bottom: 16px;">
                                @if (booking.TrangThaiBooking == "cho_dat_coc")
                                {
                                    <span style="background: rgba(201, 168, 76, 0.1); color: var(--gold); padding: 6px 12px; border-radius: 2px; font-size: 12px;">Chờ đặt cọc</span>
                                }
                                else if (booking.TrangThaiBooking == "da_thanh_toan")
                                {
                                    <span style="background: rgba(74, 158, 100, 0.1); color: #4a9e64; padding: 6px 12px; border-radius: 2px; font-size: 12px;">Đã thanh toán</span>
                                }
                                else if (booking.TrangThaiBooking == "hoan_tat")
                                {
                                    <span style="background: rgba(100, 100, 100, 0.1); color: var(--silver); padding: 6px 12px; border-radius: 2px; font-size: 12px;">Hoàn tất</span>
                                }
                                else
                                {
                                    <span style="background: rgba(217, 68, 68, 0.1); color: #d94444; padding: 6px 12px; border-radius: 2px; font-size: 12px;">Hủy</span>
                                }
                            </div>

                            <!-- Action -->
                            <a href="/Customer/Bookings" style="border: 1px solid var(--border); color: var(--gold); text-align: center; padding: 10px 16px; text-decoration: none; font-size: 12px; letter-spacing: 0.08em; border-radius: 2px; cursor: pointer;">
                                Chi tiết
                            </a>
                        </div>
                    }
                </div>

                @if (Model.Count > 6)
                {
                    <div style="margin-top: 40px; text-align: center;">
                        <a href="/Customer/Bookings" class="btn-ghost">
                            Xem tất cả →
                        </a>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 60px 24px;">
                    <p style="color: var(--silver); font-size: 16px; margin: 0 0 20px 0;">
                        Bạn chưa có buổi chụp nào
                    </p>
                    <a href="/Booking/Create" class="btn-gold" style="border: none; cursor: pointer; font-family: var(--ff-body);">
                        Đặt buổi chụp ngay
                    </a>
                </div>
            }
        </div>

        <!-- Footer -->
        <div style="margin-top: 60px; text-align: center; padding-top: 40px; border-top: 1px solid var(--border);">
            <a href="/" class="btn-ghost">
                ← Quay lại trang chủ
            </a>
        </div>

    </div>
</section>
