@model List<SeanRaw.Web.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm yêu thích";
}

<!-- ── HEADER ────────────────────────────────────────────── -->
<section style="padding: 60px 64px; background: linear-gradient(135deg, var(--ink-soft) 0%, var(--ink-mid) 100%); border-bottom: 1px solid var(--border);">
    <div style="max-width: 1200px; margin: 0 auto;">
        <p class="section-eyebrow">Mua sắm</p>
        <h1 class="hero-title" style="margin-bottom: 0;">Sản phẩm yêu thích</h1>
        <p class="hero-sub" style="color: var(--silver);">Các phụ kiện bạn đã lưu để mua sau</p>
    </div>
</section>

<!-- ── CONTENT ───────────────────────────────────────────── -->
<section style="padding: 60px 64px;">
    <div style="max-width: 1200px; margin: 0 auto;">

        @if (Model != null && Model.Any())
        {
            <!-- Products Grid -->
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px; margin-bottom: 60px;">
                @foreach (var sp in Model)
                {
                    <div style="border: 1px solid var(--border); padding: 24px; border-radius: 2px; transition: all 0.3s;">

                        <!-- Image Placeholder -->
                        <div style="background: linear-gradient(135deg, var(--ink-soft) 0%, var(--ink-mid) 100%); height: 200px; margin-bottom: 20px; border-radius: 2px; display: flex; align-items: center; justify-content: center; position: relative;">
                            <span style="color: var(--border); font-size: 14px; letter-spacing: 0.1em;">HÌNH ẢNH</span>
                            <span style="position: absolute; top: 12px; right: 12px; font-size: 20px; cursor: pointer;" title="Bỏ yêu thích">❤️</span>
                        </div>

                        <!-- Product Info -->
                        <div style="margin-bottom: 20px;">
                            <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.08em; margin: 0 0 8px 0; text-transform: uppercase;">
                                @sp.HangMayTuongThich
                            </p>
                            <h3 style="font-family: var(--ff-display); font-size: 18px; font-weight: 400; margin: 0 0 12px 0; color: var(--white);">
                                @sp.TenSanPham
                            </h3>
                            <p style="color: var(--white-dim); font-size: 13px; line-height: 1.6; margin: 0;">
                                @sp.ThongSoChiTiet
                            </p>
                        </div>

                        <!-- Price & Stock -->
                        <div style="border-top: 1px solid var(--border); padding-top: 16px; margin-bottom: 20px;">
                            <p style="color: var(--gold); font-size: 20px; font-weight: 300; margin: 0;">
                                @sp.GiaBanNiemYet.ToString("N0") ₫
                            </p>
                            <p style="color: var(--silver); font-size: 12px; margin: 4px 0 0 0;">
                                @if (sp.SoLuongTonKho > 0)
                                {
                                    @:Còn @sp.SoLuongTonKho cái
                                }
                                else
                                {
                                    <span style="color: #d94444;">Hết hàng</span>
                                }
                            </p>
                        </div>

                        <!-- Actions -->
                        <div style="display: flex; gap: 8px;">
                            @if (sp.SoLuongTonKho > 0)
                            {
                                <button class="btn-gold" style="flex: 1; border: none; cursor: pointer; font-family: var(--ff-body); padding: 10px 16px; font-size: 12px; letter-spacing: 0.1em;">
                                    Thêm vào giỏ
                                </button>
                            }
                            else
                            {
                                <button class="btn-ghost" style="flex: 1; cursor: not-allowed; opacity: 0.5; padding: 10px 16px; font-size: 12px; letter-spacing: 0.1em;">
                                    Hết hàng
                                </button>
                            }
                            <button style="border: 1px solid var(--border); color: var(--silver); background: transparent; padding: 10px 16px; font-family: var(--ff-body); cursor: pointer; font-size: 12px; letter-spacing: 0.1em;" title="Xóa khỏi yêu thích">
                                Bỏ thích
                            </button>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary -->
            <div style="text-align: center; padding-top: 40px; border-top: 1px solid var(--border);">
                <p style="color: var(--silver); font-size: 14px; margin: 0;">
                    Tổng cộng: <strong style="color: var(--white);">@Model.Count</strong> sản phẩm yêu thích
                </p>
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div style="text-align: center; padding: 100px 24px;">
                <p style="font-size: 64px; margin: 0 0 20px 0;">❤️</p>
                <h2 style="font-family: var(--ff-display); font-size: 28px; color: var(--white); margin: 0 0 12px 0; font-weight: 400;">
                    Chưa có sản phẩm yêu thích
                </h2>
                <p style="color: var(--silver); font-size: 16px; margin: 0 0 40px 0;">
                    Lưu lại các phụ kiện bạn quan tâm để xem lại bất cứ lúc nào.
                </p>
                <a href="/Home/Store" class="btn-ghost">
                    Khám phá cửa hàng →
                </a>
            </div>
        }

        <!-- Footer -->
        <div style="margin-top: 60px; text-align: center; padding-top: 40px; border-top: 1px solid var(--border);">
            <a href="/Customer/Dashboard" class="btn-ghost">
                ← Quay lại Dashboard
            </a>
        </div>

    </div>
</section>

<!-- ── STYLES ────────────────────────────────────────────── -->
<style>
    [style*="transition: all 0.3s"]:hover {
        border-color: var(--gold) !important;
    }
</style>
