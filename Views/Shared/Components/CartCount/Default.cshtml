@model int

@if (Model > 0)
{
    <span style="position: absolute; top: -6px; right: -10px; background: var(--gold); color: var(--ink); font-size: 11px; font-weight: 600; min-width: 18px; height: 18px; border-radius: 9px; display: flex; align-items: center; justify-content: center; padding: 0 4px; font-family: var(--ff-body);">
        @Model
    </span>
}
