@model dynamic
@{
    ViewData["Title"] = "Cửa hàng";
    var sanPham = ViewBag.SanPham as List<dynamic>;
}

<!-- ── HERO ──────────────────────────────────────────────── -->
<section class="hero">
    <div class="hero-visual">
        <div class="hero-light"></div>
    </div>
    <div class="hero-bg"></div>
    <div class="hero-content">
        <p class="hero-eyebrow">Cửa hàng · Phụ kiện · Chất lượng</p>
        <h1 class="hero-title">
            Phụ kiện<br>
            <em>chuyên nghiệp</em><br>
            cho nhiếp ảnh gia.
        </h1>
        <p class="hero-sub">
            Chúng tôi cung cấp các thiết bị, phụ kiện hàng đầu được lựa chọn kỹ lưỡng.
            Chất lượng cao, giá cạnh tranh, dịch vụ tuyệt vời.
        </p>
        <div class="hero-actions">
            <a href="#products" class="btn-gold">Khám phá sản phẩm</a>
            <div class="hero-divider"></div>
            <a href="/Account/Login" class="btn-ghost">Đăng nhập để mua</a>
        </div>
    </div>
</section>

<!-- ── STORE PRODUCTS ────────────────────────────────────── -->
<section id="products" style="padding: 100px 64px;">
    <p class="section-eyebrow">Cửa hàng</p>
    <h2 class="section-title">Phụ kiện & Thiết bị</h2>

    <!-- Filter/Sort Options -->
    <div style="display: flex; gap: 24px; margin-bottom: 48px; justify-content: space-between; align-items: center; flex-wrap: wrap;">
        <div style="display: flex; gap: 16px;">
            <button class="btn-ghost" style="border-color: var(--gold); color: var(--gold); border: 1px solid var(--gold); padding: 8px 16px; font-size: 12px; cursor: pointer; background: transparent; letter-spacing: 0.1em; text-transform: uppercase;">
                Tất cả
            </button>
            <button class="btn-ghost" style="padding: 8px 16px; font-size: 12px; cursor: pointer; background: transparent; letter-spacing: 0.1em; text-transform: uppercase;">
                Ống kính
            </button>
            <button class="btn-ghost" style="padding: 8px 16px; font-size: 12px; cursor: pointer; background: transparent; letter-spacing: 0.1em; text-transform: uppercase;">
                Ánh sáng
            </button>
            <button class="btn-ghost" style="padding: 8px 16px; font-size: 12px; cursor: pointer; background: transparent; letter-spacing: 0.1em; text-transform: uppercase;">
                Khác
            </button>
        </div>
        <select style="background: var(--surface); border: 1px solid var(--border); color: var(--white); padding: 8px 12px; font-family: var(--ff-body); cursor: pointer; border-radius: 2px;">
            <option>Sắp xếp: Mới nhất</option>
            <option>Giá: Thấp đến cao</option>
            <option>Giá: Cao đến thấp</option>
            <option>Bán chạy nhất</option>
        </select>
    </div>

    <!-- Products Grid -->
    <div class="packages-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px;">
        
        @if (sanPham != null && sanPham.Any())
        {
            @foreach (var sp in sanPham)
            {
                <div style="border: 1px solid var(--border); padding: 24px; transition: all 0.3s; cursor: pointer;">
                    <!-- Image Placeholder -->
                    <div style="background: linear-gradient(135deg, var(--ink-soft) 0%, var(--ink-mid) 100%); height: 200px; margin-bottom: 20px; border-radius: 2px; display: flex; align-items: center; justify-content: center;">
                        <span style="color: var(--border); font-size: 14px; letter-spacing: 0.1em;">HÌNH ẢNH</span>
                    </div>

                    <!-- Product Info -->
                    <div style="margin-bottom: 20px;">
                        <p style="color: var(--gold); font-size: 12px; letter-spacing: 0.08em; margin: 0 0 8px 0; text-transform: uppercase;">
                            Thiết bị
                        </p>
                        <h3 style="font-family: var(--ff-display); font-size: 18px; font-weight: 400; margin: 0 0 12px 0; color: var(--white);">
                            @sp.TenSanPham
                        </h3>
                        <p style="color: var(--white-dim); font-size: 13px; line-height: 1.6; margin: 0;">
                            @sp.MoTa
                        </p>
                    </div>

                    <!-- Price & Stock -->
                    <div style="border-top: 1px solid var(--border); padding-top: 16px; margin-bottom: 20px;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <p style="color: var(--gold); font-size: 20px; font-weight: 300; margin: 0;">
                                    @sp.Gia.ToString("N0") ₫
                                </p>
                                <p style="color: var(--silver); font-size: 12px; margin: 4px 0 0 0;">
                                    @if (sp.TonKho > 0) 
                                    { 
                                        @:Còn @sp.TonKho cái
                                    } 
                                    else 
                                    { 
                                        <span style="color: #d94444;">Hết hàng</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Add to Cart -->
                    @if (sp.TonKho > 0)
                    {
                        <button class="btn-gold" style="width: 100%; border: none; cursor: pointer; font-family: var(--ff-body); padding: 10px 16px; font-size: 12px; letter-spacing: 0.1em;">
                            Thêm vào giỏ
                        </button>
                    }
                    else
                    {
                        <button class="btn-ghost" style="width: 100%; cursor: not-allowed; opacity: 0.5; padding: 10px 16px; font-size: 12px; letter-spacing: 0.1em;">
                            Hết hàng
                        </button>
                    }
                </div>
            }
        }
        else
        {
            <!-- Empty State -->
            <div style="grid-column: 1 / -1; text-align: center; padding: 60px 24px;">
                <p style="color: var(--silver); font-size: 16px; margin: 0;">
                    Đang cập nhật danh sách sản phẩm...
                </p>
            </div>
        }

    </div>

</section>

<!-- ── CTA SECTION ───────────────────────────────────────── -->
<section style="padding: 100px 64px; background: linear-gradient(135deg, var(--ink-soft) 0%, var(--ink-mid) 100%);">
    <div style="max-width: 900px; margin: 0 auto; text-align: center;">
        <p class="section-eyebrow">Hỗ trợ</p>
        <h2 class="section-title">Cần tư vấn?</h2>
        <p class="hero-sub" style="margin-bottom: 40px;">
            Đội ngũ của chúng tôi sẵn lòng giúp bạn chọn phụ kiện phù hợp với nhu cầu.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center;">
            <a href="mailto:contact@sean.raw" class="btn-gold" style="border: none; cursor: pointer; font-family: var(--ff-body);">
                Liên hệ tư vấn
            </a>
            <a href="/" class="btn-ghost">
                Quay lại
            </a>
        </div>
    </div>
</section>
