@{
    ViewData["Title"] = "Chính sách riêng tư";
}

<!-- ── HERO ──────────────────────────────────────────────── -->
<section class="hero" style="padding: 120px 64px; min-height: auto;">
    <div class="hero-content" style="text-align: left; max-width: 900px;">
        <p class="hero-eyebrow">Thông tin hành chính</p>
        <h1 class="hero-title">Chính sách riêng tư</h1>
        <p class="hero-sub" style="font-size: 14px; color: var(--silver);">
            Cập nhật lần cuối: 14 tháng 6, 2026
        </p>
    </div>
</section>

<!-- ── CONTENT ───────────────────────────────────────────── -->
<section style="padding: 80px 64px; max-width: 900px; margin: 0 auto;">

    <!-- Section 1 -->
    <div style="margin-bottom: 60px;">
        <h2 class="section-title" style="margin-bottom: 24px;">1. Giới thiệu</h2>
        <p style="margin-bottom: 16px; color: var(--white-dim);">
            SEAN.RAW ("chúng tôi", "của chúng tôi") tôn trọng quyền riêng tư của bạn. Chính sách riêng tư này giải thích
            cách chúng tôi
            thu thập, sử dụng, tiết lộ và bảo vệ thông tin của bạn khi bạn sử dụng trang web của chúng tôi.
        </p>
        <p style="color: var(--white-dim);">
            Nếu bạn có bất kỳ câu hỏi hoặc lo ngại nào về chính sách này, vui lòng liên hệ với chúng tôi theo thông tin
            được cung cấp ở cuối.
        </p>
    </div>

    <!-- Section 2 -->
    <div style="margin-bottom: 60px;">
        <h2 class="section-title" style="margin-bottom: 24px;">2. Thông tin chúng tôi thu thập</h2>
        <p style="margin-bottom: 24px; color: var(--white-dim);">Chúng tôi có thể thu thập thông tin sau:</p>
        <ul style="list-style: none; padding: 0;">
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                <strong>Thông tin cá nhân:</strong> Tên, email, số điện thoại khi bạn đăng ký hoặc đặt lịch
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                <strong>Dữ liệu đặt lịch:</strong> Ngày, giờ, địa điểm, gói dịch vụ, và yêu cầu đặc biệt
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                <strong>Dữ liệu thanh toán:</strong> Thông tin giao dịch, số hóa đơn (không lưu chi tiết thẻ tín dụng)
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                <strong>Hình ảnh:</strong> Ảnh chụp của bạn trong buổi chụp, được lưu trữ an toàn
            </li>
            <li style="color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                <strong>Dữ liệu kỹ thuật:</strong> Địa chỉ IP, loại trình duyệt, hệ điều hành, thời gian truy cập
            </li>
        </ul>
    </div>

    <!-- Section 3 -->
    <div style="margin-bottom: 60px;">
        <h2 class="section-title" style="margin-bottom: 24px;">3. Cách chúng tôi sử dụng thông tin</h2>
        <p style="margin-bottom: 24px; color: var(--white-dim);">Thông tin của bạn được sử dụng để:</p>
        <ul style="list-style: none; padding: 0;">
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Cung cấp, duy trì, và cải thiện dịch vụ của chúng tôi
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Xử lý và hoàn tất các đặt lịch và giao dịch
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Gửi xác nhận, cập nhật, thông báo liên quan đến dịch vụ
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Phản hồi các yêu cầu, câu hỏi, và lo ngại của bạn
            </li>
            <li style="color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Tuân thủ các yêu cầu pháp luật và quy định
            </li>
        </ul>
    </div>

    <!-- Section 4 -->
    <div style="margin-bottom: 60px;">
        <h2 class="section-title" style="margin-bottom: 24px;">4. Bảo vệ dữ liệu</h2>
        <p style="color: var(--white-dim);">
            Chúng tôi sử dụng các biện pháp bảo mật thích hợp, bao gồm mã hóa SSL/TLS, để bảo vệ thông tin của bạn khỏi
            truy cập trái phép,
            thay đổi, tiết lộ hoặc phá hủy. Tuy nhiên, không có phương pháp truyền tải hoặc lưu trữ điện tử nào là 100%
            an toàn.
        </p>
    </div>

    <!-- Section 5 -->
    <div style="margin-bottom: 60px;">
        <h2 class="section-title" style="margin-bottom: 24px;">5. Quyền của bạn</h2>
        <p style="margin-bottom: 24px; color: var(--white-dim);">Bạn có quyền:</p>
        <ul style="list-style: none; padding: 0;">
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Truy cập thông tin cá nhân của bạn
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Yêu cầu sửa đổi hoặc xóa thông tin
            </li>
            <li style="margin-bottom: 12px; color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Từ chối hoặc rút lại sự đồng ý
            </li>
            <li style="color: var(--white-dim);">
                <span style="color: var(--gold);">• </span>
                Gửi khiếu nại đến cơ quan bảo vệ dữ liệu
            </li>
        </ul>
    </div>

    <!-- Section 6 -->
    <div style="margin-bottom: 60px;">
        <h2 class="section-title" style="margin-bottom: 24px;">6. Liên hệ</h2>
        <p style="color: var(--white-dim);">
            Nếu bạn có bất kỳ câu hỏi về chính sách riêng tư này, vui lòng liên hệ:
        </p>
        <div style="margin-top: 24px; padding: 20px; border: 1px solid var(--border); border-radius: 2px;">
            <p style="color: var(--white); margin-bottom: 8px;"><strong>SEAN.RAW</strong></p>
            <p style="color: var(--silver); font-size: 14px;">📧 contact@sean.raw</p>
            <p style="color: var(--silver); font-size: 14px;">📱 +84 (0) 123 456 789</p>
            <p style="color: var(--silver); font-size: 14px;">📍 Hanoi, Vietnam</p>
        </div>
    </div>

</section>
